# ============================================================================
# .gitignore
# Secrete (.env, *.pem) NU se comit NICIODATA. Config NEsensibil = config.env /
# *.conf (versionate). Datele/cache-ul (json/jsonl/meta/lock/bak) se ignora global.
# ============================================================================

# --- Secrete (niciodata in git) ---
.env
*.pem

# --- Config local / editor ---
.claude/settings.local.json
*.swp
*.swo
*.tmp
*~

# --- Python / build / venv ---
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.venv/
.myenv/
myenv/

# --- Date runtime / cache (cachedb/ + fisiere razlete) ---
cachedb/
*.json
*.jsonl
*.meta
*.lock
*.bak
index.html

# --- Loguri ---
*.log
*.log.[0-9]*
.logrotate.state

# --- Observabilitate tradeall (artefacte generate, nu cod) ---
tradeall_live/
logger/backtest/
