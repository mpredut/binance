# ============================================================================
# tradeall_config.env — parametri tunabili din tradeall.py (CONFIG versionat,
# se COMITE — fara secrete). Incarcat automat de tradeall.py la pornire
# (botcore.load_dotenv), inainte de orice os.environ.get(...) din fisier.
#
# 23 iul: valorile de mai jos erau constante HARDCODATE direct in cod pana
# acum — extrase aici cu valorile IMPLICITE identice (zero schimbare de
# comportament daca nu modifici nimic). Cerere user: inventariaza si scoate
# in config tot ce e parametru/prag/multiplicator din boti.
#
# ATENTIE la bani reali: schimbarea acestor valori schimba DIRECT cand/cat de
# des se trimit ordine reale BUY/SELL. Vezi research/tradeall_trigger_gate/
# pentru investigatia care a stabilit valorile de cooldown (FIRE_*) — orice
# alta modificare merita testata similar (backtest pe date reale) inainte.
# ============================================================================

# Pragul de "trend vechi" — daca un trend a supravietuit atat fara sa expire,
# se considera suficient de matur ca sa declanseze (independent de numarul
# de confirmari). Investigat (research/tradeall_trigger_gate/): acest prag e
# in practica NEATINS aproape niciodata (pragul de confirmari e mereu atins
# mai repede) — schimbarea lui, singura, probabil nu are efect vizibil.
TRADEALL_TREND_OLD_HOURS=1.9

# Praguri de "miscare mare de pret" pt ferestrele MICA si MARE (procente).
# Valorile de mai jos reproduc EXACT vechile calcule (diferenta procentuala
# intre 60000 si 60000-310, respectiv 97000 si 95000-377) — pastrate ca
# procente directe, mai usor de citit/ajustat decat perechile de preturi.
TRADEALL_PRICE_CHANGE_THRESHOLD_PCT=0.5180048459
TRADEALL_PRICE_CHANGE_THRESHOLD_BIG_PCT=2.4809130428

# Cat de "validat" trebuie sa fie un trend inainte sa fie considerat de
# incredere: minim atatea secunde de la start SI atatea confirmari.
TRADEALL_TREND_MIN_VALIDATED_SEC=30
TRADEALL_TREND_MIN_VALIDATED_CONFIRMS=3

# Numarul de confirmari dupa care un trend e considerat "consistent" (poate
# declansa un ordin prin blocurile "consistent_or_old" din logic()). Era 8*3=24.
TRADEALL_TREND_CONSISTENT_CONFIRMS=24

# Rata minima de confirmare (confirmari/timp, normalizata) ca trendul sa fie
# considerat "uniform" (nu doar zgomot rar confirmat).
TRADEALL_TREND_UNIFORM_RATE=0.08

# Pragul de "panta extrema" — cand slope-ul ferestrei mari depaseste acest
# procent (in oricare directie), blocurile "slope<=-X"/"slope>=X" din logic()
# trateaza trendul opus ca fiind deja suficient de matur pt declansare.
TRADEALL_SLOPE_EXTREME_THRESHOLD=5.1

# Cooldown per instanta de trend (22 iul, investigat riguros — vezi
# research/tradeall_trigger_gate/README.md): FARA cooldown, logic() refirea
# aceeasi decizie la fiecare evaluare cat timp trendul ramanea validat (gasit
# pe date reale: 186 BUY/0 SELL dintr-un singur trend pe TAOUSDC). Cu cooldown,
# transforma un rezultat sub buy&hold (-57.56$) intr-unul care il bate (-1.0$).
# FIRE_MAX_PER_TREND: cate executii CONFIRMATE (nu doar incercate) sunt permise
# per directie per instanta de trend, inainte sa se opreasca pana la un trend nou.
TRADEALL_FIRE_MAX_PER_TREND=3
# FIRE_MIN_RETRY_MINUTES: interval minim intre orice doua incercari (reusite
# SAU respinse de gate/weight-limit/buget) — evita reincercari la fiecare tick.
TRADEALL_FIRE_MIN_RETRY_MINUTES=6
