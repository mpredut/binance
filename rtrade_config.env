# ============================================================================
# rtrade_config.env — parametri tunabili din rtrade.py (CONFIG versionat, se
# COMITE — fara secrete). Incarcat automat de rtrade.py la pornire
# (botcore.load_dotenv), inainte de orice os.environ.get(...) din fisier.
#
# 23 iul: valorile de mai jos erau constante HARDCODATE direct in cod pana
# acum — extrase aici cu valorile IMPLICITE identice (zero schimbare de
# comportament daca nu modifici nimic). Cerere user: inventariaza si scoate
# in config tot ce e parametru/prag/multiplicator din boti.
#
# ATENTIE la bani reali: rtrade ruleaza BUY si SELL concurent (thread separat)
# pe acelasi simbol (sym.taosymbol) — schimbarea acestor valori schimba DIRECT
# preturile/orele/cantitatile ordinelor reale. BUY si SELL sunt ASIMETRICE in
# cod original (decay/ore diferite) — pastrate separat mai jos, NU unificate.
# ============================================================================

# Interval intre incercari de anulare/recreere a unui ordin neexecutat.
RTRADE_WAIT_FOR_ORDER_SEC=32

# Prag minim (fractie) sub care adjustment_percent nu mai scade (ambele directii).
RTRADE_MIN_ADJUSTMENT_PCT=0.01

# Cantitatea tranzactionata per bot (TradingBot(sym.taosymbol, RTRADE_QTY, ...)).
RTRADE_QTY=100

# Ajustarea initiala (fractie) de la care porneste adjustment_percent, calculata
# din diferenta procentuala 60000 vs 60000-380 (formula originala, pastrata in
# cod ca fallback daca variabila de mai jos nu e setata).
RTRADE_DEFAULT_ADJUSTMENT_PCT=0.0064

# Ghicit initial de spread (fractie) pt filled_buy_price/filled_sell_price la
# pornirea botului, inainte de primul ordin real.
RTRADE_INITIAL_SPREAD_PCT=0.1

# Rata de relaxare a adjustment_percent cand partea opusa e deja umpluta.
# ASIMETRIC intre BUY si SELL in codul original.
RTRADE_BUY_DECAY_PCT=0.005
RTRADE_SELL_DECAY_PCT=0.01

# Baza ferestrei "hours" (impartita la failure_count) pt calea disperata.
# ASIMETRIC intre BUY (0.3) si SELL (0.23) in codul original.
RTRADE_BUY_DESPERATE_HOURS_BASE=0.3
RTRADE_SELL_DESPERATE_HOURS_BASE=0.23

# safeback_seconds pt calea disperata (1h + 60s), comun BUY/SELL.
RTRADE_DESPERATE_SAFEBACK_SEC=3660

# "hours" pt calea normala (nimic disperat inca). ASIMETRIC — BUY 16h, SELL 12h.
RTRADE_BUY_NORMAL_HOURS=16
RTRADE_SELL_NORMAL_HOURS=12

# Ofset de pret (fractie) si fereastra "hours" pt ordinul de urmarire imediat
# dupa ce partea opusa s-a umplut (SELL la +X% dupa BUY / BUY la -X% dupa SELL).
RTRADE_FOLLOWUP_OFFSET_PCT=0.01
RTRADE_FOLLOWUP_HOURS=2.7

# Toleranta are_close pt detectia "zi proasta" si multiplicatorul aplicat lui
# adjustment_percent in acel caz. Comun ambelor directii.
RTRADE_BAD_DAY_TOLERANCE_PCT=0.1
RTRADE_BAD_DAY_MULTIPLIER=1.7

# Epsilon ca sa evite diviziunea la zero in calculul ratei profit/pierdere.
RTRADE_ZERO_EPSILON=0.0001

# Numarul maxim de esecuri acceptate inainte sa renunte la un ordin BUY/SELL.
RTRADE_MAX_FAILURES=10
