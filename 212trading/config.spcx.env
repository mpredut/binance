# ============================================================================
# 212trading — PROFIL SPCX (SpaceX).  Selecteaza cu:  python3 ipo.py --profile spcx
# Se COMITE (config versionat). Secretele sunt in .env (gitignored).
# ============================================================================

ALERT_NEW_COIN=true

# --- Instrument ---
T212_ENV=live                 # live (bani reali) sau demo (cheie demo separata)
T212_TICKER=SPCX_US_EQ        # instrumentul exact pe T212 (--find-ticker ca sa-l afli)
YAHOO_SYMBOL=SPCX             # simbol Yahoo pt pret
SYMBOL_LABEL=SpaceX
# Lansarea se detecteaza AUTOMAT: deja-listat -> imediat; IPO (volum 0) -> la deschidere.
EXPECTED_ISIN=US84615Q1031    # guard: refuza daca ISIN-ul nu se potriveste

# --- Strategie DCA + take-profit ---
STRAT_ENABLED=true            # true = strategie; false = un singur ordin (ORDER_* de mai jos)
STRAT_EXECUTE=true            # true = BANI REALI; false = PAPER. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=USD            # USD (2026-06-24): cont mutat pe USD, fara FX. Bugetul/sumele de mai jos sunt acum in USD.
# === REGLAT pt IPO SPCX cu volatilitate EXTREMA (oscilatii mari sus-jos) ===
# Logica: scaleaza pragurile la marimea swing-urilor ca sa NU vinzi pe zgomot,
# sa NU epuizezi bugetul in primul minut si sa NU fii scos pe un swing normal.
STRAT_ENTRY_PCT=6             # intrare MINIMA = 6% din buget; cu contor auto se rotunjeste in SUS ca sa acopere integral (la buget 4000, DCA 10% => intrare reala 400/10%, 9 trepte). Vrei intrare mai mica? scade DCA_PCT.
STRAT_ENTRY_DISCOUNT_PCT=0.5  # spread mare la IPO; limit putin sub piata (TTL il reaseaza daca pretul fuge)
STRAT_DCA_PCT=10              # DCA = 10% din MAX_BUDGET (= 200 la buget 2000). Cu ENTRY_PCT -> contor auto = floor((1-6%)/10%) = 9
STRAT_DCA_DROP_PCT=4.0        # CHEIE: spacing LARG -> scara DCA acopera un crash mare, nu te lasa fara buget
STRAT_DCA_TREND_GATE_PCT=0.10 # GATE DCA pe trend (2026-07-12): nu face DCA daca panta scurta (OLS 12 lumanari Yahoo 5m) < -0.10%/bara = downtrend confirmat. Motiv: DCA orb in cadere a pierdut -161$; ca gate-ul de trend din monitortrades (Binance/Kraken). 0 = OFF.
STRAT_TAKEPROFIT_PCT=11       # fallback daca STRAT_TP_LADDER e gol; cu scara, primul nivel = +11%
STRAT_TP_LADDER=11:33,20:33,30:34   # SCALE-OUT (2026-06-23): vinde 33% la +11%, 33% la +20%, 34% la +30% peste medie. Toate peste cost (profit-guard). Gol => vinde tot la TAKEPROFIT_PCT.
STRAT_CHECK_MINUTES=0.3       # piata rapida -> verifica mai des (~18s)
STRAT_MAX_BUDGET=4000         # MASTER. Cu ENTRY_PCT/DCA_PCT + contor auto: entry+N*DCA acopera INTEGRAL bugetul (intrarea absoarbe restul).
STRAT_FX_FEE_PCT=0.15         # cont e tot RON (currencyCode=RON la API), deci FX se APLICA. Pune 0 DOAR cu cont baza-USD.
STRAT_MAX_DCA_BUYS=auto       # AUTO din buget: floor((MAX_BUDGET-ENTRY)/DCA) = (2000-120)/200 = 9 trepte. Schimbi bugetul/DCA -> se recalculeaza singur.
STRAT_ORDER_TTL_MIN=3         # piata rapida: reaseaza limit-ul des daca pretul a urcat
STRAT_STOP_LOSS_PCT=30        # PROFIT-GUARD (2026-06-23): nu vinde in pierdere; 30 = doar plasa de CATASTROFA. Exit normal = doar TP (profit). Buy doar sub last-sell (REENTRY_DROP_PCT).
STRAT_TRAIL_PCT=8             # TRAILING crash-breaker (2026-07-12): vinde tot daca pretul scade 8% de la peak-ul pozitiei -> iese devreme din declin sustinut, inainte de catastrofa (backtest SPCX 3mo/1h: -7.5% -> -1.4%). Complementar SL-ului de 30% + trend-gate-ul pe DCA. Re-intra pe recul via sl_rebuy. 0 = OFF.
STRAT_TRAIL_MIN_PROFIT_PCT=4  # WARM-UP (2026-07-13, review model nou): trailing INACTIV pana pretul urca +4% peste avg -> protejeaza castigurile, NU vinde bag-ul pe un dip ordinar (respecta profit-guard; fidel MIN_PROFIT_PCT=5 din trailing Binance/Kraken, ales 4 = compromis). Worst-case vanzare ~ avg*1.04*0.92 = -4.3% vs avg. 0 = armat imediat (loss-cutter).
STRAT_SL_REBUY_ENABLED=true   # dupa catastrofa (-30%), reintra pe RECUL in sus de la minim (ca trailing Binance/Kraken), nu doar sub-vanzare -> prinde recuperarea
STRAT_SL_REBUY_BOUNCE_PCT=1.2 # recul% de la minimul de dupa SL pt re-buy

# --- Mod ordin-unic (DOAR daca STRAT_ENABLED=false) ---
ORDER_PRICE=150
ORDER_BUDGET_RON=3000
ORDER_VALIDITY=DAY
ORDER_EXECUTE=true
STRAT_REENTRY_DROP_PCT=2      # dupa TP reintra doar la -2% sub pretul vandut (anti-churn)
