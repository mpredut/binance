# ============================================================================
# 212trading — PROFIL NVIDIA.  Selecteaza cu:  python3 ipo.py --profile nvda
# Se COMITE (config versionat). Secretele sunt in .env (gitignored).
# Identic structural cu config.spcx.env, doar instrument + parametri difera.
# ============================================================================

ALERT_NEW_COIN=true

# --- Instrument ---
T212_ENV=live                 # live (bani reali) sau demo (cheie demo separata)
T212_TICKER=NVDA_US_EQ        # instrumentul exact pe T212 (--find-ticker ca sa-l afli)
YAHOO_SYMBOL=NVDA             # simbol Yahoo pt pret
SYMBOL_LABEL=NVIDIA
# Deja-listat -> porneste imediat (NVDA se tranzactioneaza in orele de piata US).
EXPECTED_ISIN=US67066G1040    # guard: refuza daca ISIN-ul nu se potriveste (NVIDIA)

# --- Strategie DCA + take-profit ---
STRAT_ENABLED=true            # true = strategie; false = un singur ordin (ORDER_* de mai jos)
STRAT_EXECUTE=true            # true = BANI REALI; false = PAPER. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=USD            # USD (2026-06-24): cont mutat pe USD, fara FX. Bugetul/sumele sunt acum in USD.
STRAT_ENTRY_PCT=15            # intrare = 15% din MAX_BUDGET (= 450 la buget 3000)
STRAT_ENTRY_DISCOUNT_PCT=0.4  # cumpara la market - acest % (limit usor sub piata)
STRAT_DCA_PCT=9.44            # DCA = 9.44% din buget (= ~283 la 3000). Cu entry 15% + auto => 9 trepte (intri mai rar). 5% dadea 17.
STRAT_DCA_DROP_PCT=1.3        # mai cumpara cand pretul scade cu acest % fata de ultima cumparare
STRAT_TAKEPROFIT_PCT=1.5      # vinde tot la pret_mediu*(1+%). peste 0.30% FX + spread => profit net
STRAT_CHECK_MINUTES=0.4       # la cate minute verifica pretul
STRAT_MAX_BUDGET=3000         # PLAFON cheltuit / ciclu (limita de siguranta)
STRAT_MAX_DCA_BUYS=auto       # AUTO din buget: floor((1-15%)/9.44%)=9 trepte (foloseste tot bugetul 3000, intrari mai rare/mari).
STRAT_FX_FEE_PCT=0.15         # cont tot RON -> FX se aplica. 0 doar cu cont baza-USD.
STRAT_ORDER_TTL_MIN=10        # reaseaza un BUY limit neexecutat dupa atatea minute daca pretul a urcat
STRAT_STOP_LOSS_PCT=30        # PROFIT-GUARD ca SPCX (2026-06-24): nu vinde in pierdere; 30 = doar plasa de CATASTROFA. Exit normal = doar TP.
STRAT_SL_REBUY_ENABLED=true   # dupa catastrofa (-30%), reintra pe RECUL in sus de la minim (ca trailing Binance/Kraken), nu doar sub-vanzare
STRAT_SL_REBUY_BOUNCE_PCT=1.2 # recul% de la minimul de dupa SL pt re-buy
STRAT_LOSS_ALERT_STEP=1       # notifica la fiecare 1% de adancire a pierderii (info, nu vinde) in loc de spam/tacere

# --- Mod ordin-unic (DOAR daca STRAT_ENABLED=false) ---
ORDER_PRICE=150
ORDER_BUDGET_RON=3000
ORDER_VALIDITY=DAY
ORDER_EXECUTE=true
STRAT_REENTRY_DROP_PCT=1.5    # dupa TP reintra doar la -1.5% sub pretul vandut (anti-churn)
