# ============================================================================
# config.rgnt.env — RGNT (Regent). PREGATIT 15 iun, NU deployat inca.
# ATENTIE: pump parabolic (+505% azi, bare 5m ±40%). E o LOTERIE, nu o strategie.
# Expunere reala plafonata INTENTIONAT la ~$1200 (sub plafonul tau de $3000):
# averaging adanc intr-un pump = mod sigur de a pierde tot.
# ============================================================================
ALERT_NEW_COIN=true

# --- Instrument ---
T212_ENV=live
T212_TICKER=RGNT_US_EQ        # confirmat via --find-ticker
YAHOO_SYMBOL=RGNT
SYMBOL_LABEL=Regentis         # Regentis Biomaterials (biotech IL), nu "Regent"
EXPECTED_ISIN=IL0012190968    # guard: refuza daca ISIN-ul nu se potriveste

# --- Strategie DCA + take-profit (sume in USD) ---
STRAT_ENABLED=true
STRAT_EXECUTE=true            # BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp
STRAT_CURRENCY=USD            # ai zis dolari
STRAT_ENTRY_PCT=30.77        # intrare = 30.77% din MAX_BUDGET (= 400 la buget 1300)
STRAT_ENTRY_DISCOUNT_PCT=5    # BUY la 5% SUB pret (intrare mai buna pe volatilitate; TTL il reaseaza daca pretul fuge)
STRAT_DCA_PCT=30.77         # DCA = 30.77% din MAX_BUDGET (= 400 la buget 1300)
STRAT_DCA_DROP_PCT=40         # adauga DOAR dupa un crash de 40% (nu pe zgomotul normal)
STRAT_MAX_DCA_BUYS=2          # EXPLICIT (nu auto): pastreaza tamponul INTENTIONAT ($1200 expunere reala, $100 tampon). Auto+acoperire-integrala ar urca intrarea la 500 si ar consuma tamponul.
STRAT_FX_FEE_PCT=0.15         # cont tot RON -> FX se aplica. 0 doar cu cont baza-USD.
STRAT_TAKEPROFIT_PCT=35       # TP calculat: +35% peste pretul mediu (1 swing real, peste fee+zgomot)
STRAT_MAX_BUDGET=1300         # plafon dur: 400 + 2x400 = 1200 expunere reala; restul tampon
STRAT_CHECK_MINUTES=0.3       # piata rapida (~18s)
STRAT_STOP_LOSS_PCT=0         # stop INUTIL aici (zgomot 40%) — iesi MANUAL daca se prabuseste
STRAT_ORDER_TTL_MIN=3         # reaseaza limit-ul des daca pretul fuge in sus
STRAT_REENTRY_DROP_PCT=10     # dupa TP reintra doar la -10% sub pretul vandut (anti-churn mai strict)
