# ============================================================================
# Kraken bot — copiaza in `.env` si completeaza cheile.
#   cp .env.example .env   &&   nano .env
# Cheile se iau din Kraken: Settings -> API -> Create API key
# Permisiuni necesare: "Query Funds", "Query Open/Closed Orders", "Create & Modify Orders",
#                      (optional "Cancel/Close Orders"). NU da permisiuni de withdrawal.
# ============================================================================
KRAKEN_API_KEY=DTHpbXIYY5/vDGi0v4MpyHkl+4xl5qvAdiZcDfWJWIBeMJBQNRy8GalF
KRAKEN_API_SECRET=InahFMvJWhUK+VZSo//AdLnfiF2zaBuuCAmkzU4qHTGaj2JTllYabGL/xeuJ/4NrvLXZh2XoghqH2BjerGGSoA==

# --- Notificari (acelasi mecanism ca 121trade) ---
NTFY_TOPIC=spacex-marius-7831
ALERT_TO_EMAIL=tuderp@gmail.com
SMTP_USERNAME=tuderp@gmail.com
SMTP_PASSWORD=

# ============================================================================
# Instrument (SCHIMBA AICI ca sa treci pe alta pereche)
#   HYPE e listat:  KRAKEN_PAIR=HYPEEUR  sau  HYPEUSD
#   SPCX NU e listat pe Kraken inca -> botul va astepta pana apare.
#   Afla numele exact cu:  python3 kraken_bot.py --find-pair hype
# ============================================================================
KRAKEN_PAIR=HYPEEUR
SYMBOL_LABEL=Hyperliquid

# ============================================================================
# Strategie DCA + take-profit  (sumele sunt in valuta de cotare a perechii)
# ============================================================================
STRAT_EXECUTE=false           # false = PAPER (simulare); true = BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only (doar acumulare)
STRAT_CURRENCY=EUR            # doar eticheta (valuta de cotare a perechii)
STRAT_ENTRY=50                # cumpararea initiala (EUR)
STRAT_ENTRY_DISCOUNT_PCT=0.2  # cumpara la market - acest %
STRAT_DCA=30                  # cumparare pe scadere (EUR)
STRAT_DCA_DROP_PCT=2.0        # mai cumpara cand pretul scade cu acest %
STRAT_TAKEPROFIT_PCT=1.0      # vinde tot la pret_mediu*(1+%).  !! min ~0.6% (fee Kraken ~0.5% round-trip)
STRAT_CHECK_MINUTES=2         # la cate minute verifica pretul
STRAT_MAX_BUDGET=500          # PLAFON cheltuit / ciclu (siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere
STRAT_ORDER_TTL_MIN=10        # reaseaza un buy neexecutat dupa atatea minute daca pretul a urcat
