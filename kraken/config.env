# ============================================================================
# Kraken — CONFIG versionat (se COMITE). Secretele sunt in .env (gitignored).
# Botul incarca .env intai (secrete + override-uri locale castiga), apoi acest fisier.
# ============================================================================
KRAKEN_PAIR=HYPEUSD           # HYPEEUR sau HYPEUSD (--find-pair hype ca sa-l afli)
SYMBOL_LABEL=Hyperliquid

# ============================================================================
# Strategie DCA + take-profit (sumele sunt in valuta de cotare a perechii)
# ============================================================================
STRAT_EXECUTE=true            # false = PAPER; true = BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=USD            # valuta de cotare a perechii (HYPEUSD -> USD)
STRAT_ENTRY=100               # cumpararea initiala
STRAT_ENTRY_DISCOUNT_PCT=0.8  # cumpara la market - acest %
STRAT_DCA=50                  # cumparare pe scadere
STRAT_DCA_DROP_PCT=2.0        # mai cumpara cand pretul scade cu acest %
STRAT_TAKEPROFIT_PCT=1.9      # vinde tot la pret_mediu*(1+%). min ~0.6% (fee Kraken ~0.5% round-trip)
STRAT_CHECK_MINUTES=2         # la cate minute verifica pretul
STRAT_MAX_BUDGET=1000         # PLAFON cheltuit / ciclu (siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere
STRAT_ORDER_TTL_MIN=10        # reaseaza un buy neexecutat dupa atatea minute daca pretul a urcat
STRAT_STOP_LOSS_PCT=10        # SIGURANTA: vinde tot daca pierderea nerealizata >= 10% (0 = oprit)
