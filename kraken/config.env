# ============================================================================
# Kraken — CONFIG versionat (se COMITE). Secretele sunt in .env (gitignored).
# Botul incarca .env intai (secrete + override-uri locale castiga), apoi acest fisier.
# ============================================================================
KRAKEN_PAIR=HYPEUSD           # HYPEEUR sau HYPEUSD (--find-pair hype ca sa-l afli)
SYMBOL_LABEL=Hyperliquid

# ============================================================================
# Strategie DCA + take-profit (sumele sunt in valuta de cotare a perechii)
# ============================================================================
STRAT_EXECUTE=true            # false = PAPER; true = BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=USD            # valuta de cotare a perechii (HYPEUSD -> USD)
STRAT_ENTRY=300               # cumpararea initiala (3x, 14 iun: pune cash idle la treaba — moderat)
STRAT_ENTRY_DISCOUNT_PCT=0.8  # cumpara la market - acest %
STRAT_DCA=150                 # cumparare pe scadere (3x odata cu ENTRY)
STRAT_DCA_DROP_PCT=1.0        # mai cumpara cand pretul scade cu acest % (sweep 30z: drop 1.0 e pârghia)
STRAT_TAKEPROFIT_PCT=5.0      # vinde tot la pret_mediu*(1+%) — calareste trendul, vinde rar (sweep +8.8%)
STRAT_CHECK_MINUTES=2         # la cate minute verifica pretul
STRAT_MAX_BUDGET=3000         # PLAFON cheltuit / ciclu (siguranta). Efectiv ~$1800 (300+10x150);
                              # plafonul 3000 = headroom daca cresti MAX_DCA_BUYS. Restul cash = tampon.
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere
STRAT_ORDER_TTL_MIN=10        # reaseaza un buy neexecutat dupa atatea minute daca pretul a urcat
STRAT_STOP_LOSS_PCT=7         # SIGURANTA: vinde tot daca pierderea nerealizata >= 10% (0 = oprit)

# ============================================================================
# xStocks / alocare IPO SPCX (kraken_xstock_watch.py) — monitorizeaza alocarea de 7500$
# ============================================================================
XSTOCK_REGEX=SPCX|SPACEX      # ce cauta in balanta + perechi (regex, case-insensitive)
XSTOCK_QUOTE=USD              # daca apar mai multe perechi (USD+EUR), prefer-o pe asta
XSTOCK_CHECK_MINUTES=1        # la cate minute verifica
XSTOCK_ALLOC_PRICE=141.75     # costul REAL (135 + 5% prima Kraken, din ledger)
XSTOCK_TP_ALERT_PCT=41        # TRANSA 1 ~00: vinde JUMATATE (2.14 buc)
XSTOCK_TP2_ALERT_PCT=81       # TRANSA 2 ~56: vinde restul (sau sambata seara, oricum)
XSTOCK_SL_ALERT_PCT=12        # alerta cand scade cu acest % sub pretul alocarii
XSTOCK_YAHOO=SPCX             # pret subiacent (Yahoo) cat timp perechea nu e pe API-ul Kraken

# --- PORNIRE AUTOMATA bot (watcher-ul porneste singur kraken_bot la alocare) ---
# Conditii: alocare in cont + pereche listata pe API + XSTOCK_ALLOC_PRICE > 0.
# Watcher-ul tine PID-ul botului in stare: la restart NU dubleaza; daca botul
# moare, il reporneste (strategia isi reia starea proprie — fara pozitii duble).
XSTOCK_AUTOSTART=true         # false = doar alerte, fara pornire automata
XSTOCK_BOT_PAPER=false        # true = botul pornit automat ruleaza PAPER (test)
XSTOCK_BOT_TP_PCT=48          # tinta lui Marius: vinde la ~$200 (135 x 1.48 = 199.80)
                              # 20=lacom (risti sa ratezi varful si sa cobori spre stop-loss)
XSTOCK_BOT_DCA_DROP_PCT=4
XSTOCK_BOT_SL_PCT=12
XSTOCK_BOT_DCA=500            # USD per cumparare pe scadere (sume aprobate 12 iun)
XSTOCK_BOT_MAX_BUDGET=4000    # plafon bani aditionali / ciclu
XSTOCK_BOT_CHECK_MINUTES=1

# --- Adoptare pozitie existenta in kraken_bot (folosit de auto-start; manual:) ---
#   STRAT_ADOPT_COST=<pret_alocare> python3 kraken_bot.py --pair <PERECHE_SPCX>
STRAT_ADOPT_COST=0            # >0 = adopta pozitia din cont la acest cost mediu (pretul alocarii)
STRAT_ADOPT_QTY=0             # 0 = citeste automat cantitatea din balanta
STRAT_REENTRY_DROP_PCT=1.5    # dupa TP reintra doar la -1.5% sub pretul vandut (calibrat pe ritmul
                              # dip-urilor din uptrend ~1%; in piata care scade, creste-l la 3)
                              # TODO post-SPCX: adaptiv dupa volatilitate/trend (cu trailing stop)
# --- TP IN TRANSE (optional): "3:50,6:50" = vinde 50% la +3%, restul la +6% ---
STRAT_TP_TRANCHES=            # gol = TP clasic (un singur ordin pe toata pozitia)
