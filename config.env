# ============================================================================
# binance (radacina) — CONFIG versionat (se COMITE). Secretele sunt in .env (gitignored).
# Incarcat de run_price_monitor.py si price_monitor_watchdog.py dupa .env.
# ============================================================================
ALERT_NEW_COIN=True           # alerteaza la monede noi descoperite

# ============================================================================
# LEGACY: ordin / strategie SPCX — MUTAT in 212trading/ (config.spcx.env, config.nvda.env).
# Pastrat aici doar pt compatibilitate; monitorul de pret NU foloseste aceste valori.
# ============================================================================
T212_ENV=live                 # live (bani reali) sau demo
ORDER_PRICE=150               # plafon: pretul LIMIT maxim per actiune, USD
ORDER_BUDGET_RON=3000         # buget RON; cantitatea se calculeaza automat la cursul live
ORDER_VALIDITY=DAY            # DAY sau GTC (= GOOD_TILL_CANCEL)
ORDER_EXECUTE=true            # true = ordine reale; false = dry-run
ORDER_EXPECTED_ISIN=US84615Q1031   # guard: ordinul se plaseaza DOAR daca ISIN-ul se potriveste (SpaceX)
STRAT_ENABLED=true            # true = la lansare porneste strategia in loc de un singur ordin
STRAT_EXECUTE=false           # false = PAPER (doar simuleaza); true = tranzactii REALE
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_ENTRY_EUR=400           # marimea cumpararii initiale (EUR)
STRAT_ENTRY_DISCOUNT_PCT=0.002  # cumpara la market - acest %
STRAT_DCA_EUR=100             # marimea unei cumparari pe scadere (EUR)
STRAT_DCA_DROP_PCT=0.01       # cumpara din nou cand pretul scade cu acest % fata de ultima cumparare
STRAT_TAKEPROFIT_PCT=0.02     # vinde tot cand pretul >= pret_mediu * (1 + acest %)
STRAT_CHECK_MINUTES=0.3       # la cate minute verifica pretul
STRAT_MAX_BUDGET_EUR=500      # PLAFON total cheltuit pe ciclu (siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere (siguranta)
STRAT_ORDER_TTL_MIN=10        # reaseaza un BUY limit neexecutat dupa atatea minute daca pretul a urcat
