# ============================================================================
# monitortrades_config.env — parametri GLOBALI tunabili din monitortrades.py
# (CONFIG versionat, se COMITE — fara secrete). Incarcat automat de
# monitortrades.py la pornire (botcore.load_dotenv), inainte de orice
# os.environ.get(...) din fisier.
#
# 23 iul: valorile de mai jos erau constante HARDCODATE direct in cod pana
# acum — extrase aici cu valorile IMPLICITE identice (zero schimbare de
# comportament daca nu modifici nimic). Cerere user: inventariaza si scoate
# in config tot ce e parametru/prag/multiplicator din boti.
#
# ATENTIE: acesta e config-ul GLOBAL (una din cele 3 nivele ale flotei — vezi
# root config.env pt fleet-wide). Parametrii PER-INSTRUMENT (gain/lost/maxage/
# hardtp/buy_budget etc.) raman NESCHIMBATI in monitortrades.conf (text simplu,
# nu .env) si in instruments.conf (namespace mt.*) — nu se dubleaza aici.
# ============================================================================

# Toleranta "aproape de prag" (are_close, botcore) folosita la TOATE pragurile
# din monitor_price_and_trade (HARD-TP, gain_threshold, lost_threshold, gain
# vs sell_price) — un pret care rateaza pragul cu putin nu trebuie tratat ca
# "nimic interesant".
MT_ARE_CLOSE_TOLERANCE_PCT=1.0

# Cat de "recente" trebuie sa fie tranzactiile BUY/SELL individuale ca sa fie
# considerate inca in curs (get_relevant_trade) inainte sa permita un nou
# trade de acelasi tip.
MT_RECENT_TRADE_BLOCK_HOURS=3

# Cat de recenta trebuie sa fie CEA MAI RECENTA tranzactie (buy SAU sell) ca
# sa blocheze orice alt trade nou pe simbolul respectiv.
MT_ALL_TRADES_BLOCK_HOURS=1

# Interval de asteptare intre doua iteratii ale buclei principale (main()).
MT_MAIN_LOOP_SLEEP_SEC=48

# Ofset de pret (in valuta de cotare) adaugat peste pretul curent la plasarea
# unui BUY (limit putin peste piata, ca sa se execute mai sigur).
MT_BUY_PRICE_OFFSET=0.5

# Fereastra de "safeback" (ore) trimisa la _place_guarded -> inst.place(hours=...)
# pt ordinele SELL (HARD-TP + cele doua cazuri din trend-down), respectiv BUY.
MT_SELL_SAFEBACK_HOURS=2
MT_BUY_SAFEBACK_HOURS=48

# ============================================================================
# Documentat aici pt vizibilitate, dar INCA citit direct din os.environ in cod
# (nu are nevoie de acest fisier ca sa functioneze — mecanism preexistent):
# MT_GUARD_WINDOW_DAYS=12   # fereastra gardei de profit (zile), vezi main()
# ============================================================================
