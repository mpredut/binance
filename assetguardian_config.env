# ============================================================================
# assetguardian_config.env — parametri tunabili din assetguardian.py (CONFIG
# versionat, se COMITE — fara secrete). Incarcat automat de assetguardian.py
# la pornire (botcore.load_dotenv), inainte de orice os.environ.get(...) din
# fisier.
#
# 23 iul: valorile de mai jos erau constante HARDCODATE direct in cod pana
# acum — extrase aici cu valorile IMPLICITE identice (zero schimbare de
# comportament daca nu modifici nimic). Cerere user: inventariaza si scoate
# in config tot ce e parametru/prag/multiplicator din boti.
#
# ATENTIE la bani reali: schimbarea acestor valori schimba DIRECT cand
# assetguardian vinde tot portofoliul (crestere) sau cumpara cu tot cash-ul
# disponibil (scadere). Vezi comentariul din cod: TARGET_GROWTH_PERCENT=100
# e intentionat "practic oprit" (walk-forward 291z a aratat ca vanzarea
# agresiva pierde fata de detinere) — protectia reala de crash e in
# trailing_stop.py, nu aici.
# ============================================================================

# Interval intre doua evaluari ale buclei principale (run_forever).
AG_CHECK_INTERVAL_SEC=54

# Prag de crestere (%) fata de valoarea minima din fereastra de referinta la
# care se declanseaza sell_all_assets(). 100 = practic oprit (vezi comentariul
# din cod pt motivul istoric).
AG_TARGET_GROWTH_PCT=100.0

# Prag de scadere (%) la care se declanseaza buy_with_all_cash().
AG_TARGET_DROP_PCT=7.0

# Fereastra (minute) folosita ca referinta pt calculul cresterii/scaderii
# portofoliului (cauta minimul din cache in aceasta fereastra). 1440 = 24h.
AG_REFERENCE_MINUTES_BACK=1440

# Fractia din cash-ul liber folosita la buy_with_all_cash() (0.995 = 99.5%,
# restul ramane tampon pt comisioane/precizie).
AG_BUY_USE_CASH_RATIO=0.995
