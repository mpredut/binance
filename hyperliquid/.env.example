# ============================================================================
# Hyperliquid bot — copiaza in `.env` si completeaza.
#   cp .env.example .env
#
# AUTENTIFICARE: foloseste un AGENT / API WALLET, NU cheia contului principal!
#   Pe Hyperliquid: More -> API -> "Generate" agent wallet -> Approve.
#   Agentul poate tranzactiona, dar NU poate retrage fonduri.
#   - HL_SECRET_KEY        = cheia privata a agent wallet-ului (0x...)
#   - HL_ACCOUNT_ADDRESS   = adresa contului principal (cel cu USDC)
# ============================================================================
HL_SECRET_KEY=
HL_ACCOUNT_ADDRESS=
HL_MAINNET=true              # true = mainnet (bani reali), false = testnet

# --- Notificari ---
NTFY_TOPIC=spacex-marius-7831
ALERT_TO_EMAIL=tuderp@gmail.com
SMTP_USERNAME=tuderp@gmail.com
SMTP_PASSWORD=

# ============================================================================
# Instrument (PERP long-only)
# ============================================================================
HL_COIN=HYPE                 # moneda perp (HYPE, BTC, ETH, ...)
HL_LEVERAGE=1                # levier (1 = cvasi-spot; >1 = amplifici castig SI risc de lichidare)
HL_DIRECTION=long            # long (castig cand urca) | short (castig cand SCADE)
SYMBOL_LABEL=Hyperliquid HYPE

# ============================================================================
# Strategie DCA + take-profit  (sumele in USDC, colateralul Hyperliquid)
# ============================================================================
STRAT_EXECUTE=false          # false = PAPER; true = BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp         # avg_tp sau dca_only
STRAT_CURRENCY=USDC
STRAT_ENTRY=50               # cumpararea initiala (USDC)
STRAT_ENTRY_DISCOUNT_PCT=0.2 # cumpara (long) la market - acest %
STRAT_DCA=30                 # adaugare pe scadere (USDC)
STRAT_DCA_DROP_PCT=2.0       # mai cumpara la scadere de acest %
STRAT_TAKEPROFIT_PCT=0.5     # vinde tot la pret_mediu*(1+%). Fee HL minuscul -> poate fi strans
STRAT_CHECK_MINUTES=1        # la cate minute verifica pretul
STRAT_MAX_BUDGET=500         # PLAFON USDC / ciclu
STRAT_MAX_DCA_BUYS=10
STRAT_ORDER_TTL_MIN=10
HL_FEE_PCT=0.035             # fee estimat /leg pt P&L net (maker ~0.015, taker ~0.045)

# ============================================================================
# DELTA-NEUTRAL (funding farming) — folosit de dn_bot.py
#   long SPOT + short PERP, marimi egale -> neutru pe pret, castigi funding.
#   Necesita USDC in AMBELE conturi: Spot (cumperi token) + Perp (margine short).
# ============================================================================
HL_SPOT_PAIR=@107            # perechea spot HYPE/USDC pe Hyperliquid (--funding/--status ca sa verifici)
HL_SPOT_TOKEN=HYPE           # tokenul spot detinut pe long
DN_NOTIONAL=100              # USDC per picior (long spot 100 + short perp 100)
DN_MIN_FUNDING_HR_PCT=0.0    # funding/ora minim ca sa STAI in pozitie (sub el -> inchide). 0 = orice funding pozitiv
DN_REBALANCE_PCT=5           # rebalansezi cand delta depaseste acest % din marime
DN_CHECK_MINUTES=5           # la cate minute verifica
