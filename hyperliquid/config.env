# ============================================================================
# Hyperliquid — CONFIG versionat (se COMITE). Secretele (chei wallet) sunt in .env.
# Botul incarca .env intai (secrete + override-uri locale castiga), apoi acest fisier.
# ============================================================================
HL_MAINNET=true              # true = mainnet (bani reali), false = testnet

# ============================================================================
# Instrument (PERP long-only)
# ============================================================================
HL_COIN=HYPE                 # moneda perp (HYPE, BTC, ETH, ...)
HL_LEVERAGE=1                # levier (1 = cvasi-spot, lichidare foarte departe)
HL_DIRECTION=long            # long (castig cand urca) | short (castig cand SCADE) — doar hl_bot.py
SYMBOL_LABEL=Hyperliquid HYPE

# ============================================================================
# Strategie DCA + take-profit (sumele in USDC, colateralul Hyperliquid)
# ============================================================================
STRAT_EXECUTE=true           # false = PAPER; true = BANI REALI. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp         # avg_tp sau dca_only
STRAT_CURRENCY=USDC
STRAT_ENTRY=50               # cumpararea initiala (USDC)
STRAT_ENTRY_DISCOUNT_PCT=0.2 # cumpara (long) la market - acest %
STRAT_DCA=30                 # adaugare pe scadere (USDC)
STRAT_DCA_DROP_PCT=2.0       # mai cumpara la scadere de acest %
STRAT_TAKEPROFIT_PCT=0.5     # vinde tot la pret_mediu*(1+%). Fee HL minuscul -> poate fi strans
STRAT_CHECK_MINUTES=1        # la cate minute verifica pretul
STRAT_MAX_BUDGET=500         # PLAFON USDC / ciclu
STRAT_MAX_DCA_BUYS=10
STRAT_ORDER_TTL_MIN=10
STRAT_STOP_LOSS_PCT=8        # SIGURANTA directional: inchide tot daca pierderea >= 8% (0=oprit)
HL_FEE_PCT=0.035             # fee estimat /leg pt P&L net (maker ~0.015, taker ~0.045)

# --- Semnal de trend / predictie (doar pt strategia DIRECTIONALA hl_bot.py) ---
HL_SIGNAL_GATE=false         # true = intra DOAR daca semnalul e in favoarea directiei
SIGNAL_SOURCE=off            # off | builtin (trend din lumanari) | file (modelul tau scrie signal.json)
SIGNAL_FILE=signal.json      # fisierul pe care LSTM-ul/price-analysis-ul tau il scrie
SIGNAL_FAST_H=12             # media rapida (ore) pt trend-ul builtin
SIGNAL_SLOW_H=48             # media lenta (ore)
SIGNAL_BAND_PCT=0.3          # zona neutra: sub acest % diferenta = neutral
SIGNAL_MAX_AGE_MIN=60        # daca semnalul din fisier e mai vechi de atat -> neutral

# ============================================================================
# DELTA-NEUTRAL (dn_bot.py) — funding farming, market-neutral, SIGUR
# ============================================================================
HL_SPOT_PAIR=                # GOL = rezolvata AUTOMAT din HL_SPOT_TOKEN (HYPE -> @107)
HL_SPOT_TOKEN=HYPE           # implicit = HL_COIN; schimbi moneda dintr-un singur loc
DN_NOTIONAL=100              # USDC per picior (long spot 100 + short perp 100)
# regula inteligenta de funding (anti-churn): mediere + histerezis + timp minim
DN_ENTRY_FUNDING_HR_PCT=0.0   # deschide cand funding MEDIU >= asta
DN_EXIT_FUNDING_HR_PCT=-0.005 # inchide DOAR cand funding MEDIU < asta (negativ -> fara churn)
DN_FUNDING_WINDOW_H=4         # mediaza funding-ul pe atatea ore (ignora citiri izolate)
DN_MIN_HOLD_H=6               # nu inchide mai devreme de atatea ore
DN_CHECK_MINUTES=5           # la cate minute verifica
DN_REBALANCE_PCT=5           # rebalanseaza la acest % delta
DN_LIQ_ALERT_PCT=20          # alerta + auto-reduce cand pretul e la acest % de lichidare
DN_AUTO_PROTECT=true         # reduce automat pozitia daca se apropie lichidarea
DN_REDUCE_PCT=25             # cu cat % reduce la fiecare interventie
DN_PERP_LEVERAGE=1           # levier short (1 = lichidare ~+100%, cel mai sigur)
