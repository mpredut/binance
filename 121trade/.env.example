CMC_API_KEY=""

SMTP_USERNAME=""
SMTP_PASSWORD=""
ALERT_TO_EMAIL=""
PHONE_ALERT_URL=""
ALERT_NEW_COIN=True

#trade 121 config params
#keys
T212_API_KEY=""
T212_API_SECRET=""

#alert config
NTFY_TOPIC=""


# ============================================================================
# Instrument de tranzactionat — SCHIMBA AICI ca sa treci pe alt simbol
# ============================================================================
T212_ENV=live                 # live (bani reali) sau demo (cheie demo separata)

#T212_TICKER=NVDA_US_EQ        # instrumentul exact pe T212 (--find-ticker ca sa-l afli)
#YAHOO_SYMBOL=NVDA             # simbol Yahoo pt pret (optional; derivat din T212_TICKER)
#SYMBOL_LABEL=NVIDIA           # eticheta pt afisare/notificari
# Lansarea se detecteaza AUTOMAT, identic pt orice simbol: deja-listat (NVDA) -> porneste
# imediat; IPO (SPCX, volum 0) -> asteapta deschiderea. (--skip-wait sare peste, de urgenta.)
#EXPECTED_ISIN=US67066G1040    # guard optional: refuza daca ISIN-ul nu se potriveste (NVIDIA)

T212_TICKER=SPCX_US_EQ
YAHOO_SYMBOL=SPCX
SYMBOL_LABEL=SpaceX
EXPECTED_ISIN=US84615Q1031

# ============================================================================
# Strategie DCA + take-profit
# ============================================================================
STRAT_ENABLED=true            # true = strategie; false = un singur ordin (ORDER_* de mai jos)
STRAT_EXECUTE=true            # ⚠ true = BANI REALI; false = PAPER. Flag-ul --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only (doar acumulare)
STRAT_CURRENCY=EUR            # valuta sumelor de mai jos (RON / EUR / USD)
STRAT_ENTRY=100               # cumpararea initiala (RON)
STRAT_ENTRY_DISCOUNT_PCT=0.2  # cumpara la market - acest % (limit usor sub piata)
STRAT_DCA=150                 # cumparare pe scadere (RON)
STRAT_DCA_DROP_PCT=1.0        # mai cumpara cand pretul scade cu acest % fata de ultima cumparare
STRAT_TAKEPROFIT_PCT=0.6      # vinde tot la pret_mediu*(1+%).  peste 0.30% FX + spread => profit net
STRAT_CHECK_MINUTES=0.5       # la cate minute verifica pretul (0.5 = 30s)
STRAT_MAX_BUDGET=2000         # ⚠ PLAFON 2000 RON cheltuiti / ciclu (limita ta de siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere
STRAT_ORDER_TTL_MIN=10        # reaseaza un BUY limit neexecutat dupa atatea minute daca pretul a urcat

# ============================================================================
# Mod ordin-unic (folosit DOAR daca STRAT_ENABLED=false)
# ============================================================================
ORDER_PRICE=150
ORDER_BUDGET_RON=3000
ORDER_VALIDITY=DAY
ORDER_EXECUTE=true            # ⚠ true = BANI REALI; false = PAPER. Flag-ul --paper forteaza PAPER.

