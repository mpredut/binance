# ============================================================================
# 121trade — PROFIL SPCX (SpaceX).  Selecteaza cu:  python3 ipo.py --profile spcx
# Se COMITE (config versionat). Secretele sunt in .env (gitignored).
# ============================================================================

ALERT_NEW_COIN=true

# --- Instrument ---
T212_ENV=live                 # live (bani reali) sau demo (cheie demo separata)
T212_TICKER=SPCX_US_EQ        # instrumentul exact pe T212 (--find-ticker ca sa-l afli)
YAHOO_SYMBOL=SPCX             # simbol Yahoo pt pret
SYMBOL_LABEL=SpaceX
# Lansarea se detecteaza AUTOMAT: deja-listat -> imediat; IPO (volum 0) -> la deschidere.
EXPECTED_ISIN=US84615Q1031    # guard: refuza daca ISIN-ul nu se potriveste

# --- Strategie DCA + take-profit ---
STRAT_ENABLED=true            # true = strategie; false = un singur ordin (ORDER_* de mai jos)
STRAT_EXECUTE=true            # true = BANI REALI; false = PAPER. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=EUR            # valuta sumelor de mai jos
STRAT_ENTRY=100               # cumpararea initiala
STRAT_ENTRY_DISCOUNT_PCT=0.2  # cumpara la market - acest % (limit usor sub piata)
STRAT_DCA=150                 # cumparare pe scadere
STRAT_DCA_DROP_PCT=1.0        # mai cumpara cand pretul scade cu acest % fata de ultima cumparare
STRAT_TAKEPROFIT_PCT=0.6      # vinde tot la pret_mediu*(1+%). peste 0.30% FX + spread => profit net
STRAT_CHECK_MINUTES=0.5       # la cate minute verifica pretul (0.5 = 30s)
STRAT_MAX_BUDGET=2000         # PLAFON cheltuit / ciclu (limita de siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere
STRAT_ORDER_TTL_MIN=10        # reaseaza un BUY limit neexecutat dupa atatea minute daca pretul a urcat
STRAT_STOP_LOSS_PCT=10        # SIGURANTA: vinde tot daca pierderea nerealizata >= 10% (0 = oprit)

# --- Mod ordin-unic (DOAR daca STRAT_ENABLED=false) ---
ORDER_PRICE=150
ORDER_BUDGET_RON=3000
ORDER_VALIDITY=DAY
ORDER_EXECUTE=true
