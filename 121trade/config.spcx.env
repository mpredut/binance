# ============================================================================
# 121trade — PROFIL SPCX (SpaceX).  Selecteaza cu:  python3 ipo.py --profile spcx
# Se COMITE (config versionat). Secretele sunt in .env (gitignored).
# ============================================================================

ALERT_NEW_COIN=true

# --- Instrument ---
T212_ENV=live                 # live (bani reali) sau demo (cheie demo separata)
T212_TICKER=SPCX_US_EQ        # instrumentul exact pe T212 (--find-ticker ca sa-l afli)
YAHOO_SYMBOL=SPCX             # simbol Yahoo pt pret
SYMBOL_LABEL=SpaceX
# Lansarea se detecteaza AUTOMAT: deja-listat -> imediat; IPO (volum 0) -> la deschidere.
EXPECTED_ISIN=US84615Q1031    # guard: refuza daca ISIN-ul nu se potriveste

# --- Strategie DCA + take-profit ---
STRAT_ENABLED=true            # true = strategie; false = un singur ordin (ORDER_* de mai jos)
STRAT_EXECUTE=true            # true = BANI REALI; false = PAPER. --paper forteaza PAPER.
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit) sau dca_only
STRAT_CURRENCY=EUR            # valuta sumelor de mai jos
# === REGLAT pt IPO SPCX cu volatilitate EXTREMA (oscilatii mari sus-jos) ===
# Logica: scaleaza pragurile la marimea swing-urilor ca sa NU vinzi pe zgomot,
# sa NU epuizezi bugetul in primul minut si sa NU fii scos pe un swing normal.
STRAT_ENTRY=120               # intrare moderata: pastreaza munitie pt dip-ul de dupa spike
STRAT_ENTRY_DISCOUNT_PCT=0.5  # spread mare la IPO; limit putin sub piata (TTL il reaseaza daca pretul fuge)
STRAT_DCA=200                 # dip-uri mari merita cumparari mai mari
STRAT_DCA_DROP_PCT=4.0        # CHEIE: spacing LARG -> scara DCA acopera un crash mare, nu te lasa fara buget
STRAT_TAKEPROFIT_PCT=5.0      # prinde swing-uri REALE, nu zgomot (0.6% ar vinde instant si ai rata spike-ul)
STRAT_CHECK_MINUTES=0.3       # piata rapida -> verifica mai des (~18s)
STRAT_MAX_BUDGET=2000         # PLAFON cheltuit / ciclu (ridica-l daca vrei expunere mai mare)
STRAT_MAX_DCA_BUYS=8          # 8 nivele x 4% ≈ 32% interval de scadere acoperit
STRAT_ORDER_TTL_MIN=3         # piata rapida: reaseaza limit-ul des daca pretul a urcat
STRAT_STOP_LOSS_PCT=7         # larg cat sa supravietuiasca swing-urilor IPO, dar opreste un colaps real (>~30% de la intrare)

# --- Mod ordin-unic (DOAR daca STRAT_ENABLED=false) ---
ORDER_PRICE=150
ORDER_BUDGET_RON=3000
ORDER_VALIDITY=DAY
ORDER_EXECUTE=true
