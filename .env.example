CMC_API_KEY="c26bf3a0-5c25-4a8e-8ca8-4ce3ed7b6f20"

SMTP_USERNAME=""
SMTP_PASSWORD=""
ALERT_TO_EMAIL=""
PHONE_ALERT_URL=""
ALERT_NEW_COIN=True

#trade 121 config params
#keys
T212_API_KEY=""
T212_API_SECRET=""

#alert config
NTFY_TOPIC="spacex-marius-7831"


# --- Ordin automat SPCX ---
T212_ENV=live            # live (bani reali) sau demo (cont de test, cheie demo separata)
ORDER_PRICE=150          # plafon: pretul LIMIT maxim per actiune, USD
ORDER_BUDGET_RON=3000     # buget RON; cantitatea se calculeaza automat la cursul live
# ORDER_QTY=2            # alternativa la buget: numar fix de actiuni
ORDER_VALIDITY=DAY       # DAY sau GTC (= GOOD_TILL_CANCEL)
ORDER_EXECUTE=true       # true = ordine reale; false = dry-run
ORDER_EXPECTED_ISIN=US84615Q1031   # guard: ordinul se plaseaza DOAR daca ISIN-ul se potriveste (SpaceX)

# --- Strategie DCA + take-profit (optional; inlocuieste ordinul unic) ---
STRAT_ENABLED=true           # true = la lansare porneste strategia in loc de un singur ordin
STRAT_EXECUTE=false           # false = PAPER (doar simuleaza/logheaza); true = tranzactii REALE
STRATEGY_MODE=avg_tp          # avg_tp (cost mediu + take-profit global) sau dca_only (doar acumulare)
STRAT_ENTRY_EUR=400            # marimea cumpararii initiale (EUR)
STRAT_ENTRY_DISCOUNT_PCT=0.002  # cumpara la market - acest %
STRAT_DCA_EUR=100              # marimea unei cumparari pe scadere (EUR)
STRAT_DCA_DROP_PCT=0.01          # 2 - cumpara din nou cand pretul scade cu acest % fata de ultima cumparare
STRAT_TAKEPROFIT_PCT=0.02      # 2 - vinde tot cand pretul >= pret_mediu * (1 + acest %)
STRAT_CHECK_MINUTES=0.3         # la cate minute verifica pretul
STRAT_MAX_BUDGET_EUR=500      # PLAFON total cheltuit pe ciclu (siguranta)
STRAT_MAX_DCA_BUYS=10         # numar maxim de cumparari pe scadere (siguranta)
STRAT_ORDER_TTL_MIN=10        # daca un BUY limit nu se executa in atatea minute si pretul a urcat, il reaseaza
